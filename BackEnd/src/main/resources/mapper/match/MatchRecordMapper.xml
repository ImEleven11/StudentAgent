<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uestc.studentagent.backend.match.mapper.MatchRecordMapper">

    <resultMap id="MatchRecordMap" type="com.uestc.studentagent.backend.match.entity.MatchRecordEntity">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="profile_id" property="profileId"/>
        <result column="job_id" property="jobId"/>
        <result column="overall_score" property="overallScore"/>
        <result column="basic_score" property="basicScore"/>
        <result column="skill_score" property="skillScore"/>
        <result column="potential_score" property="potentialScore"/>
        <result column="details_json" property="detailsJson"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByUserAndProfileId" resultMap="MatchRecordMap">
        SELECT id, user_id, profile_id, job_id, overall_score, basic_score, skill_score, potential_score, details_json, created_at
        FROM match_records
        WHERE user_id = #{userId}
          AND profile_id = #{profileId}
        ORDER BY created_at DESC, id DESC
    </select>

    <insert id="insert"
            parameterType="com.uestc.studentagent.backend.match.entity.MatchRecordEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO match_records (
            user_id,
            profile_id,
            job_id,
            overall_score,
            basic_score,
            skill_score,
            potential_score,
            details_json
        ) VALUES (
            #{userId},
            #{profileId},
            #{jobId},
            #{overallScore},
            #{basicScore},
            #{skillScore},
            #{potentialScore},
            #{detailsJson}
        )
    </insert>

</mapper>
