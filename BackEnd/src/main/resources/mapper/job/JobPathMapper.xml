<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uestc.studentagent.backend.job.mapper.JobPathMapper">

    <resultMap id="JobPathMap" type="com.uestc.studentagent.backend.job.entity.JobPathEntity">
        <id column="id" property="id"/>
        <result column="job_id" property="jobId"/>
        <result column="path_type" property="pathType"/>
        <result column="step_order" property="stepOrder"/>
        <result column="target_job_id" property="targetJobId"/>
        <result column="target_job_title" property="targetJobTitle"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByJobId" parameterType="long" resultMap="JobPathMap">
        SELECT id, job_id, path_type, step_order, target_job_id, target_job_title, description, created_at
        FROM job_paths
        WHERE job_id = #{jobId}
        ORDER BY path_type ASC, step_order ASC, id ASC
    </select>

</mapper>
